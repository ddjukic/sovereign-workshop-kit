// materials/templates/openclaw.json
// AlpenTech GmbH — Sovereign Agent Team Configuration
// Workshop: Sovereign Agentic Systems, AI Factory Austria
{
  // Custom LLM providers (beyond built-in Anthropic, OpenAI, OpenRouter, Ollama)
  models: {
    providers: {
      "langdock": {
        baseUrl: "https://api.langdock.com/v1",
        apiKey: "${LANGDOCK_API_KEY}",
        api: "openai-completions",
        models: [
          {
            id: "claude-sonnet-4-5",
            name: "Claude Sonnet 4.5 (Langdock EU)",
            reasoning: false,
            input: ["text", "image"],
            contextWindow: 200000,
            maxTokens: 8192
          },
          {
            id: "gemini-3-pro",
            name: "Gemini 3 Pro (Langdock EU)",
            reasoning: false,
            input: ["text"],
            contextWindow: 1000000,
            maxTokens: 8192
          }
        ]
      }
    }
  },

  agents: {
    defaults: {
      // All agents narrate their actions for workshop observability
      verboseDefault: "on"
    },
    list: [
      {
        id: "orchestrator",
        default: true,
        name: "AlpenTech Orchestrator",
        model: "langdock/claude-sonnet-4-5",
        workspace: "~/.openclaw/workspace-orchestrator",
        agentDir: "~/.openclaw/agents/orchestrator/agent",
        identity: { name: "AlpenTech AI", emoji: "shield" },
        subagents: { allowAgents: ["researcher", "analyst", "local"] },
        tools: {
          profile: "messaging",
          allow: ["sessions_spawn", "sessions_send", "sessions_list"]
        }
      },
      {
        id: "researcher",
        name: "Research Agent",
        model: "openrouter/qwen/qwen3.5-coder",
        workspace: "~/.openclaw/workspace-research",
        agentDir: "~/.openclaw/agents/researcher/agent",
        identity: { name: "Researcher", emoji: "magnifying_glass" },
        tools: {
          profile: "full",
          deny: ["write", "edit"]
        }
      },
      {
        id: "analyst",
        name: "Sensitive Data Analyst",
        model: "langdock/claude-sonnet-4-5",
        workspace: "~/.openclaw/workspace-sensitive",
        agentDir: "~/.openclaw/agents/analyst/agent",
        identity: { name: "Analyst", emoji: "lock" },
        tools: {
          profile: "minimal",
          allow: ["read", "write", "exec", "grep"],
          deny: ["browser", "canvas"]
        },
        sandbox: {
          mode: "all",
          scope: "agent",
          docker: {
            network: "none",
            memory: "2g",
            cpus: 2,
            readOnlyRoot: true,
            capDrop: ["ALL"]
          }
        }
      },
      {
        id: "local",
        name: "Local Sovereign Agent",
        model: "ollama/qwen3.5:3b",
        workspace: "~/.openclaw/workspace-local",
        agentDir: "~/.openclaw/agents/local/agent",
        identity: { name: "Local", emoji: "house" },
        tools: { profile: "coding" },
        sandbox: {
          mode: "all",
          docker: { network: "none", memory: "4g", cpus: 2 }
        }
      }
    ]
  },

  // Agent-to-agent communication (required for orchestrator delegation)
  tools: {
    agentToAgent: {
      enabled: true,
      allow: ["orchestrator", "researcher", "analyst", "local"]
    }
  },

  // NOTE: MCP servers are configured via the external mcporter bridge,
  // not in openclaw.json. See: https://docs.openclaw.ai/tools/mcp
  // To use PageIndex MCP, run: mcporter --url https://chat.pageindex.ai/mcp

  // Channel routing: web dashboard -> orchestrator (Telegram/WhatsApp optional)
  bindings: [
    { agentId: "orchestrator", match: { channel: "web", accountId: "default" } }
  ],

  channels: {
    web: {
      accounts: {
        default: {}
      }
    }
  }
}
